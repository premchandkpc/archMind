# =============================================================
# CivilMind AI — Environment Configuration
# Copy to .env and fill in your values
# =============================================================

# ---------- App ----------
APP_NAME="CivilMind AI"
DEBUG=true
SECRET_KEY=your-secret-key-here

# ---------- PostgreSQL ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=civilmind
POSTGRES_PASSWORD=civilmind
POSTGRES_DB=civilmind

# ---------- Qdrant ----------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=civilmind

# ---------- MinIO ----------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=civilmind-docs
MINIO_SECURE=false

# ---------- Neo4j ----------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- LLM (OpenCode Zen) ----------
OPENCODE_API_KEY=your-opencode-api-key-here
LLM_MODEL=opencode/claude-sonnet-4-5
VISION_MODEL=opencode/gpt-5

# ---------- Embeddings ----------
EMBEDDING_PROVIDER=bge
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# ---------- OCR (Worker only) ----------
PADDLEOCR_ENABLED=true
TESSERACT_LANG=eng
