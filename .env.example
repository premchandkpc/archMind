# =============================================================
# CivilMind AI — Environment Configuration
# Copy to .env and fill in your values
# =============================================================

# ---------- App ----------
APP_NAME=CivilMind AI
DEBUG=true
SECRET_KEY=your-secret-key-here

# ---------- PostgreSQL ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=civilmind
POSTGRES_PASSWORD=civilmind
POSTGRES_DB=civilmind

# ---------- Qdrant ----------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=civilmind

# ---------- MinIO ----------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=civilmind-docs
MINIO_SECURE=false

# ---------- Neo4j ----------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0

# ============================================================
# LLM — Provider-Agnostic
# ============================================================
# Supported providers: opencode | openai | anthropic | custom
LLM_PROVIDER=opencode
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=
# For opencode: https://opencode.ai/zen/v1
# For openai:   https://api.openai.com/v1
# For custom:   your OpenAI-compatible endpoint
LLM_CHAT_MODEL=opencode/claude-sonnet-4-5
LLM_VISION_MODEL=opencode/gpt-5

# Anthropic-specific (only used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_VERSION=2023-06-01

# LLM defaults
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_SECONDS=60

# ---------- Embeddings ----------
EMBEDDING_PROVIDER=bge
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# ---------- Vision Tool ----------
VISION_MAX_IMAGE_SIZE_MB=20
VISION_DEFAULT_PROMPT=Describe this architectural image in detail.

# ---------- OCR Tool ----------
OCR_MAX_IMAGE_SIZE_MB=20

# ---------- SQL Query Tool ----------
SQL_QUERY_TIMEOUT_SECONDS=5
SQL_QUERY_MAX_ROWS=1000

# ---------- Document Formats ----------
SUPPORTED_DOC_FORMATS=.pdf,.docx,.xlsx,.png,.jpg,.jpeg

# ---------- Embedding Dimensions ----------
EMBEDDING_DIMS_CSV=BAAI/bge-base-en-v1.5=768,BAAI/bge-small-en-v1.5=384

# ---------- OCR (Worker only) ----------
PADDLEOCR_ENABLED=true
TESSERACT_LANG=eng
